---
import PageLayout from '@/layouts/PageLayout.astro';
import { SITE } from '@/lib/site';
---

<PageLayout
  title={`Not found | ${SITE.name}`}
  description="Page not found."
  lang="en"
  canonicalPath="/404/"
>
  <h1 class="font-serif text-3xl font-semibold text-accent">404</h1>
  <p class="mt-4 text-ink/80">This page does not exist.</p>
  <p class="mt-6">
    <a href="/">Back home</a>
  </p>
</PageLayout>
