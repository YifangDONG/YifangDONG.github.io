---
import TagLink from '@/components/TagLink.astro';
import PageLayout from '@/layouts/PageLayout.astro';
import { SITE, pairAlternates } from '@/lib/site';
import { publishedPosts, postSlug } from '@/lib/blog';

const posts = await publishedPosts('en');
---

<PageLayout
  title={`Blog | ${SITE.name}`}
  description="All English posts."
  lang="en"
  canonicalPath="/blog/"
  alternates={pairAlternates('/blog/', '/zh-cn/blog/')}
>
  <h1 class="font-serif text-3xl font-semibold text-accent">Blog</h1>
  <ul class="mt-8 space-y-4">
    {
      posts.map((p) => (
        <li class="rounded-lg border border-muted bg-raised p-4 shadow-sm">
          <a href={`/blog/${postSlug(p)}/`} class="no-underline">
            <span class="font-serif text-xl font-semibold text-ink">{p.data.title}</span>
          </a>
          <time class="mt-1 block text-sm text-ink/60" datetime={p.data.pubDate.toISOString()}>
            {p.data.pubDate.toLocaleDateString('en', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
          <p class="mt-2 text-sm text-ink/75">{p.data.description}</p>
          {
            p.data.tags?.length ? (
              <p class="mt-3 flex flex-wrap gap-2 text-xs text-ink/55">
                {p.data.tags.map((t) => (
                  <TagLink href={`/tags/${encodeURIComponent(t)}/`}>{t}</TagLink>
                ))}
              </p>
            ) : null
          }
        </li>
      ))
    }
  </ul>
</PageLayout>
